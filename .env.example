# Koda environment template.
# Copy this file to `.env.local` and fill in real values.
# Every key is OPTIONAL — Koda gracefully falls back to mock data
# when a key is missing, so the app stays runnable on a fresh clone.

# Anthropic — powers Auditor + PRD Studio with live Claude calls.
# Without this key, both endpoints return curated mock responses.
ANTHROPIC_API_KEY=

# Supabase — powers project persistence + magic-link auth.
# All three must be set together. The service-role key is server-only;
# never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: production site URL for absolute OG metadata links.
# Leave blank for local development.
NEXT_PUBLIC_SITE_URL=
